@model List<BookListItemViewModel>

@{
    ViewData["Title"] = "Book Catalog";
    var totalItems = Model.Count;
}

<div class="page-header">
    <div>
        <h2 class="page-title">Book Catalog</h2>
        <p class="page-description">
            Đây là trang danh sách các quyển sách của cửa hàng.
        </p>
    </div>

    <div>
        <a class="btn btn-primary" href="/Books/Stats">
            Xem thống kê tồn kho
        </a>
    </div>
</div>

<div class="info-panel">
    <strong>Tổng số sách:</strong> @totalItems
</div>

@if (Model.Count == 0)
{
    <p>Chưa có quyển sách nào trong hệ thống.</p>
}
else
{
    <table class="table table-bordered table-striped align-middle">
        <thead>
            <tr>
                <th>Tên sách</th>
                <th>Nhóm</th>
                <th>Giá bán</th>
                <th>Số lượng</th>
                <th>Giá trị tồn kho</th>
                <th>Trạng thái</th>
                <th>Chi tiết</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Category</td>
                    <td>@item.PriceText</td>
                    <td>@item.Quantity</td>
                    <td>@item.InventoryValueText</td>
                    <td>
                        <span class="@item.StockStatusClass">
                            @item.StockStatus
                        </span>
                    </td>
                    <td>
                        <a href="/Books/Detail/@item.Id">Xem</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<p class="mt-4">
    <a class="btn btn-light" href="/">
        Quay lại trang chủ
    </a>
</p>
