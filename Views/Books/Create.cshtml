@model BookCreateViewModel

@{
    ViewData["Title"] = "Create Book";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Create Book</h2>
        <p class="page-description">
            Form POST dùng asp-for để bind dữ liệu vào BookCreateViewModel.
        </p>
    </div>

    <a class="btn btn-light"
       asp-controller="Books"
       asp-action="Index">
        Quay lại danh sách
    </a>
</div>

<div class="form-layout">
    <form class="form-box"
          asp-controller="Books"
          asp-action="Create"
          method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="All"></div>

        <div class="form-group">
            <label asp-for="Name">Tên sản phẩm</label>
            <input asp-for="Name"
                   class="form-control"
                   placeholder="Ví dụ: The Great Gatsby" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Category">Danh mục</label>
            <input asp-for="Category"
                   class="form-control"
                   placeholder="Ví dụ: Văn học" />
            <span asp-validation-for="Category" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Author">Tác giả</label>
            <input asp-for="Author"
                   class="form-control"
                   placeholder="Ví dụ: John Doe" />
            <span asp-validation-for="Author" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Price">Giá bán</label>
            <input asp-for="Price"
                   class="form-control"
                   placeholder="Ví dụ: 450000" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Quantity">Số lượng</label>
            <input asp-for="Quantity"
                   class="form-control"
                   placeholder="Ví dụ: 12" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="MinStock">Mức tồn tối thiểu</label>
            <input asp-for="MinStock"
                   class="form-control"
                   placeholder="Ví dụ: 5" />
            <span asp-validation-for="MinStock" class="text-danger"></span>
        </div>

        <button class="btn" type="submit">
            Save Book
        </button>

        <a class="btn btn-secondary"
           asp-controller="Books"
           asp-action="Index">
            Back to List
        </a>
    </form>

    <div class="info-box">
        <h3>Model Binding từ Form POST</h3>

        <p>
            Khi bấm Save, ASP.NET Core sẽ đọc các input trong form
            và tự map vào BookCreateViewModel.
        </p>

        <p>
            Ví dụ input có <strong>asp-for="Name"</strong>
            thì dữ liệu sẽ được bind vào property <strong>Name</strong>.
        </p>

        <p>
            Nếu tên input không khớp với property, action có thể nhận null hoặc giá trị mặc định.
        </p>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
