@model AspNetWeek2.Mvc.ViewModels.BookDetailViewModel

<div class="container mt-4">
    <div class="card shadow" style="max-width: 650px; margin: auto;">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0">Chi Tiết Sản Phẩm</h3>
            <span class="badge @(Model.Quantity <= 0 ? "bg-danger" : (Model.Quantity <= Model.MinStock ? "bg-warning text-dark" : "bg-success")) fs-6">
                @Model.StockStatus
            </span>
        </div>
        <div class="card-body">
            <div class="row mb-2">
                <div class="col-sm-4 font-weight-bold">Tên sách:</div>
                <div class="col-sm-8 text-secondary">@Model.Name</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 font-weight-bold">Tác giả:</div>
                <div class="col-sm-8 text-secondary">@Model.Author</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 font-weight-bold">Thể loại:</div>
                <div class="col-sm-8 text-secondary">@Model.Category</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 font-weight-bold">Giá bán:</div>
                <div class="col-sm-8 text-primary fw-bold">@Model.PriceText</div> </div>
            <hr />
            <div class="row mb-2">
                <div class="col-sm-4 font-weight-bold">Tồn kho / Tối thiểu:</div>
                <div class="col-sm-8">@Model.Quantity / @Model.MinStock cuốn</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 font-weight-bold">Giá trị tồn kho:</div>
                <div class="col-sm-8 text-success">@Model.InventoryValueText</div> </div>
            
            <div class="alert @(Model.Quantity <= Model.MinStock ? "alert-warning" : "alert-info") mt-3">
                <strong>Gợi ý hệ thống:</strong> @Model.ReorderSuggestion
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a href="/Books" class="btn btn-secondary">Quay lại danh sách</a>
                @if (Model.Quantity > 0)
                {
                    <a href="/Orders/Create" class="btn btn-success shadow-sm">Đặt mua ngay</a>
                }
            </div>
        </div>
    </div>
</div>