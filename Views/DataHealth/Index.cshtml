@model Dictionary<string, string>

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <h2 class="card-title mb-0">Hệ Thống Kiểm Tra Sức Khỏe Dữ Liệu (Data Health)</h2>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th style="width: 30%">Nội Dung Kiểm Tra</th>
                        <th style="width: 70%">Trạng Thái / Kết Quả Hệ Thống</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-secondary">@item.Key</td>
                            <td>
                                @if (item.Value.Contains("Thất bại") || item.Value.Contains("Sai"))
                                {
                                    <span class="text-danger fw-bold">@item.Value</span>
                                }
                                else
                                {
                                    <span class="text-success">@item.Value</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="mt-3">
        <a href="/Books" class="btn btn-primary">Quay lại danh sách chính</a>
    </div>
</div>